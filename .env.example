# --- Auth: нужно хотя бы одно из двух ---

# Вариант 1: API ключ (официальный)
ARKHAM_API_KEY=your_api_key_here

# Вариант 2: Cookie (по инструкции поддержки)
# Несколько кук разделяются через "; "
# ARKHAM_COOKIE=AMP_f072531383=JTdC...

# Можно указать оба — будут переданы вместе
# ARKHAM_API_KEY=your_key
# ARKHAM_COOKIE=AMP_f072531383=JTdC...

# --- Прочее ---
ARKHAM_BASE_URL=https://intel.arkm.com/api
ARKHAM_PROVIDER=arkham   # available: arkham
